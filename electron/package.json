{
  "name": "codebot-desktop",
  "version": "2.9.0",
  "description": "CodeBot AI Desktop \u2014 Autonomous AI coding agent",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac",
    "build:dmg": "electron-builder --mac dmg",
    "build:dir": "electron-builder --mac dir",
    "postbuild:dir": "codesign --force --deep --sign - 'dist/mac-arm64/CodeBot AI.app' 2>/dev/null; xattr -cr 'dist/mac-arm64/CodeBot AI.app' 2>/dev/null; echo 'App signed (ad-hoc) and quarantine cleared.'",
    "prebuild": "node scripts/stage-production-deps.js",
    "prebuild:dmg": "node scripts/stage-production-deps.js",
    "prebuild:dir": "node scripts/stage-production-deps.js",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "build:universal": "electron-builder --mac --universal"
  },
  "author": "Ascendral",
  "license": "MIT",
  "devDependencies": {
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1"
  },
  "overrides": {
    "tar": "^7.4.0",
    "yauzl": "^3.2.0",
    "@tootallnate/once": "^2.0.0"
  },
  "build": {
    "appId": "com.ascendral.codebot",
    "productName": "CodeBot AI",
    "afterSign": "notarize.js",
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "icons/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        },
        {
          "target": "dir",
          "arch": [
            "universal"
          ]
        }
      ],
      "identity": "alex pinkevich (PWG7UVB6S4)",
      "darkModeSupport": true,
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "entitlements.plist",
      "entitlementsInherit": "entitlements.plist"
    },
    "dmg": {
      "title": "CodeBot AI",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "files": [
      "main.js",
      "preload.js",
      "icons/**"
    ],
    "extraResources": [
      {
        "from": "../dist",
        "to": "codebot/dist",
        "filter": [
          "**/*",
          "!**/*.test.*",
          "!**/*.spec.*",
          "!**/*.map"
        ]
      },
      {
        "from": "../bin",
        "to": "codebot/bin",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "staging/node_modules",
        "to": "codebot/node_modules",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../package.json",
        "to": "codebot/package.json"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icons/icon.icns"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Development",
      "icon": "icons/icon.icns"
    }
  }
}
