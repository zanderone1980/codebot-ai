{
  "name": "codebot-ai",
  "version": "2.7.2",
  "description": "Zero-dependency autonomous AI agent. Code, browse, search, automate. Works with any LLM — Ollama, Claude, GPT, Gemini, DeepSeek, Groq, Mistral, Grok.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "codebot": "bin/codebot"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli.js",
    "test": "node scripts/run-tests.js",
    "lint": "eslint src/ && tsc --noEmit",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write 'src/**/*.ts' '*.json' '*.md'",
    "format:check": "prettier --check 'src/**/*.ts' '*.json' '*.md'",
    "typecheck": "tsc --noEmit",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "postbuild": "node -e \"require('fs').cpSync('src/dashboard/static','dist/dashboard/static',{recursive:true})\"",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "ai-agent",
    "agent",
    "autonomous",
    "agentic",
    "coding-assistant",
    "code-generation",
    "code-review",
    "automation",
    "automation-bot",
    "llm",
    "openai",
    "claude",
    "gpt",
    "gemini",
    "ollama",
    "deepseek",
    "groq",
    "mistral",
    "local-llm",
    "browser-automation",
    "cli",
    "web-search",
    "security",
    "enterprise",
    "devtools",
    "developer-tools",
    "vscode-extension",
    "github-action",
    "sarif",
    "policy-engine",
    "mcp",
    "swarm",
    "multi-agent",
    "multi-llm"
  ],
  "author": "Ascendral Software Development & Innovation",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zanderone1980/codebot-ai.git"
  },
  "homepage": "https://github.com/zanderone1980/codebot-ai#readme",
  "bugs": {
    "url": "https://github.com/zanderone1980/codebot-ai/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/dashboard/static/**",
    "!dist/**/*.test.*",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "cord-engine": "^4.1.0"
  }
}
