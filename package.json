{
  "name": "codebot-ai",
  "version": "2.10.1",
  "description": "Open-source autonomous coding agent with a cryptographic audit trail. Delegate coding work, verify every action. Runs against local (Ollama/LM Studio/vLLM) or cloud LLMs.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "codebot": "bin/codebot"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli.js",
    "test": "node scripts/run-tests.js",
    "lint": "eslint src/ && tsc --noEmit",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write 'src/**/*.ts' '*.json' '*.md'",
    "format:check": "prettier --check 'src/**/*.ts' '*.json' '*.md'",
    "typecheck": "tsc --noEmit",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "postbuild": "node -e \"require('fs').cpSync('src/dashboard/static','dist/dashboard/static',{recursive:true})\"",
    "prepublishOnly": "npm run build",
    "pretest": "npm run build",
    "postinstall": "patch-package"
  },
  "keywords": [
    "autonomous-agent",
    "coding-agent",
    "ai-agent",
    "agent",
    "audit-log",
    "hash-chain",
    "sarif",
    "governance",
    "compliance",
    "policy-engine",
    "constitutional-ai",
    "secure-by-default",
    "local-first",
    "offline",
    "air-gapped",
    "ollama",
    "lm-studio",
    "vllm",
    "llm",
    "openai",
    "claude",
    "gpt",
    "gemini",
    "deepseek",
    "groq",
    "mistral",
    "mcp",
    "multi-llm",
    "cli",
    "devtools",
    "developer-tools",
    "vscode-extension",
    "github-action",
    "issue-to-pr",
    "swe-bench"
  ],
  "author": "Ascendral",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ascendral/codebot-ai.git"
  },
  "homepage": "https://github.com/Ascendral/codebot-ai#readme",
  "bugs": {
    "url": "https://github.com/Ascendral/codebot-ai/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/dashboard/static/**",
    "!dist/**/*.test.*",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "flatted": "^3.4.2",
    "patch-package": "^8.0.1",
    "postinstall-postinstall": "^2.1.0",
    "prettier": "^3.8.1",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "cord-engine": "^4.1.0"
  },
  "optionalDependencies": {
    "@ai-operations/ops-storage": "^0.1.0",
    "@ai-operations/spark-engine": "^0.1.0"
  }
}
