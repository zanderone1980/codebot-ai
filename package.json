{
  "name": "codebot-ai",
  "version": "2.0.1",
  "description": "Zero-dependency autonomous AI agent. Code, browse, search, automate. Works with any LLM — Ollama, Claude, GPT, Gemini, DeepSeek, Groq, Mistral, Grok.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "codebot": "bin/codebot"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli.js",
    "test": "node --test dist/*.test.js dist/**/*.test.js",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "ai-agent",
    "agent",
    "autonomous",
    "agentic",
    "coding-assistant",
    "code-generation",
    "code-review",
    "automation",
    "automation-bot",
    "llm",
    "openai",
    "claude",
    "gpt",
    "gemini",
    "ollama",
    "deepseek",
    "groq",
    "mistral",
    "local-llm",
    "browser-automation",
    "cli",
    "web-search",
    "security",
    "enterprise",
    "devtools",
    "developer-tools",
    "vscode-extension",
    "github-action",
    "sarif",
    "policy-engine",
    "mcp"
  ],
  "author": "Ascendral Software Development & Innovation",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zanderone1980/codebot-ai.git"
  },
  "homepage": "https://github.com/zanderone1980/codebot-ai#readme",
  "bugs": {
    "url": "https://github.com/zanderone1980/codebot-ai/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "!dist/**/*.test.*",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "devDependencies": {
    "typescript": "^5.5.0",
    "@types/node": "^20.0.0"
  }
}
